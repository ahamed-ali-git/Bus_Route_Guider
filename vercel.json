{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "DB_USER": "postgres",
    "DB_HOST": "localhost",
    "DB_NAME": "Your_Database",
    "DB_PASSWORD": "Your_Password",
    "DB_PORT": "5432",
    "SESSION_SECRET": "Your_Secret",
    "GOOGLE_CLIENT_ID": "Your_Client_ID",
    "GOOGLE_CLIENT_SECRET": "Your_Client_Secret",
    "PORT": "3000"
  }
}
